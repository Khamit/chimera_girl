{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Game",
            "type": "shell",
            "command": "cd build && cmake .. && make -j8",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Game",
            "type": "shell",
            "command": "./build/game",
            "dependsOn": ["Build Game"],
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}